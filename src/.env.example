# Copy this file to ".env" and place it next to YSMInstaller.exe.
# Typical locations when running from Visual Studio / MSBuild:
#   src\bin\Debug\.env
#   src\bin\Release\.env


# Write ysm_installer_log.txt next to the executable instead of %TEMP%.
LOG_NEXT_TO_EXE=true

# Use mocked WARNO scan paths and sample mod catalog (no real game install).
MOCK_WARNO_PATHS=true
